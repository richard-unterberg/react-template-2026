{
  "name": "react-template-2026",
  "version": "1.0.0",
  "description": "vite template for modern react projects. pre-configured meta framework, useful defaults, dark/light mode, css inlining, optimized for github pages deploy",
  "scripts": {
    "dev": "vike dev",
    "build": "vike build",
    "preview": "vike build && vike preview",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:knip": "pnpm knip",
    "prepare": "lefthook install",
    "verify": "pnpm format && pnpm run lint && pnpm check:knip && pnpm run typecheck"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vike": "0.4.260",
    "vike-react": "^0.6.25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@marmo/react": "^1.0.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@unterberg/vite-beasties-output": "^0.1.16",
    "@vitejs/plugin-react": "^6.0.3",
    "daisyui": "^5.6.3",
    "knip": "^6.21.0",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
